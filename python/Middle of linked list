def get_middle_node(head):
    
    if (head == None):
        return head;
    
    if (head.next == None):
        return head;

    # Replace this placeholder return statement with your code
    slow = head;
    fast = head;
    
    while (fast and fast.next != None):
        slow = slow.next;
        fast = fast.next.next;
    return slow;
