class Node:
    def __init__(self, data):
        self.data = data;
        self.next = None;
    
    
headNode = Node(10);
node1 = Node(20);
node2 = Node(30);

headNode.next = node1;
node1.next = node2;

current = headNode;
while current:
    print(current.data, end="->");
    current = current.next;
